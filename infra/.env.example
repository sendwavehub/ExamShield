# Copy to infra/.env and fill in real values before starting services.
# Never commit .env to version control.

# PostgreSQL
POSTGRES_PASSWORD=examshield

# RabbitMQ
RABBITMQ_USER=examshield
RABBITMQ_PASSWORD=examshield

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=examshield

# Set to true to create the bucket with S3 Object Lock (WORM, COMPLIANCE mode).
# Once a bucket is created with Object Lock it cannot be reversed — use false for dev.
MINIO_ENABLE_LOCK=false

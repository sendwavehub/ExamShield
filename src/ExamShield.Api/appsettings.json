{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Auth":   { "PermitLimit": 10,  "WindowSeconds": 60 },
    "Upload": { "PermitLimit": 20,  "WindowSeconds": 60 },
    "Global": { "PermitLimit": 200, "WindowSeconds": 60 }
  }
}

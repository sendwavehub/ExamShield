{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=examshield;Username=examshield;Password=examshield"
  },
  "Jwt": {
    "Secret": "dev-secret-change-in-production-must-be-at-least-32-chars!!",
    "Issuer": "ExamShield",
    "Audience": "ExamShield",
    "ExpirationMinutes": 60
  },
  "Cache": {
    "Type": "Redis",
    "ConnectionString": "localhost:6379"
  },
  "Messaging": {
    "Type": "RabbitMQ",
    "Host": "localhost",
    "Port": 5672,
    "Username": "examshield",
    "Password": "examshield",
    "VirtualHost": "/",
    "OcrQueueName": "ocr.requests"
  },
  "Storage": {
    "Type": "MinIO",
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "examshield",
    "UseSSL": false,
    "EnableObjectLock": false,
    "RetentionDays": 3650,
    "RetentionMode": "COMPLIANCE"
  },
  "Ocr": {
    "Type": "Stub",
    "Endpoint": "http://localhost:8081/ocr/extract",
    "TimeoutSeconds": 30
  },
  "Watermark": {
    "HmacKeyBase64": "ZGV2LXdhdGVybWFyay1rZXktY2hhbmdlLWluLXByb2Q="
  },
  "Alerts": {
    "Channels": [
      {
        "Type": "Webhook",
        "Url": "https://hooks.example.com/examshield",
        "Enabled": false
      },
      {
        "Type": "Slack",
        "Url": "https://hooks.slack.com/services/REPLACE_ME",
        "Enabled": false
      },
      {
        "Type": "Teams",
        "Url": "https://outlook.office.com/webhook/REPLACE_ME",
        "Enabled": false
      },
      {
        "Type": "LineNotify",
        "Token": "REPLACE_ME",
        "Enabled": false
      },
      {
        "Type": "Email",
        "SmtpHost": "localhost",
        "SmtpPort": 1025,
        "SmtpUseSsl": false,
        "EmailFrom": "examshield@localhost",
        "EmailTo": "admin@localhost",
        "Enabled": false
      }
    ]
  }
}
